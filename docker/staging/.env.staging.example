# ============================================
# AMB Management - Staging Environment
# ============================================
# Copy this file to .env.staging and fill in the values:
#   cp .env.staging.example .env.staging

# Database
DB_HOST=amb-postgres
DB_PORT=5442
DB_USERNAME=amb_user
DB_PASSWORD=change_me_strong_password
DB_DATABASE=db_amb_hanmam

# API
NODE_ENV=production
API_PORT=3019
API_PREFIX=api/v1
JWT_SECRET=change_me_random_jwt_secret_key_min_32chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
CORS_ORIGINS=https://hm-stg.hanmam.kr
FRONTEND_URL=https://hm-stg.hanmam.kr
SWAGGER_ENABLED=false
API_KEY_ENCRYPTION_SECRET=change_me_32byte_encryption_key!
ENCRYPTION_KEY=change_me_64_character_hex_string_for_custom_app_encryption_key

# Claude AI
CLAUDE_API_KEY=

# SMTP (Mail)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AMB Management <noreply@amoeba.co.kr>

# Google Drive (optional)
# Option A: File path (requires volume mount)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=
# Option B: JSON string (recommended for Docker - paste the service account JSON here)
GOOGLE_SERVICE_ACCOUNT_KEY_JSON=
GOOGLE_DRIVE_IMPERSONATE_EMAIL=
GOOGLE_DRIVE_BILLING_ROOT_FOLDER_ID=

# Frontend (build-time)
VITE_API_BASE_URL=https://hm-stg.hanmam.kr/api/v1
