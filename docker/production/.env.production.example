# ============================================
# AMB Management - Production Environment
# ============================================
# Copy this file to .env.production and fill in the values:
#   cp .env.production.example .env.production

# Database
DB_HOST=amb-postgres
DB_PORT=5442
DB_USERNAME=amb_user
DB_PASSWORD=change_me_strong_password
DB_DATABASE=db_amb_hanmam

# API
NODE_ENV=production
API_PORT=3019
API_PREFIX=api/v1
JWT_SECRET=change_me_random_jwt_secret_key_min_32chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
CORS_ORIGINS=https://hm-amb.hanmam.kr
FRONTEND_URL=https://hm-amb.hanmam.kr
AMA_API_URL=http://amb-api:3019/api/v1
SWAGGER_ENABLED=false
API_KEY_ENCRYPTION_SECRET=change_me_32byte_encryption_key!
ENCRYPTION_KEY=change_me_64_character_hex_string_for_custom_app_encryption_key
PORTAL_BRIDGE_INTERNAL_TOKEN=change_me_shared_internal_bridge_token

# Claude AI
CLAUDE_API_KEY=

# SMTP (Mail)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AMB Management <noreply@amoeba.co.kr>

# Google Drive (optional)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=
GOOGLE_SERVICE_ACCOUNT_KEY_JSON=
GOOGLE_DRIVE_IMPERSONATE_EMAIL=
GOOGLE_DRIVE_BILLING_ROOT_FOLDER_ID=

# Frontend (build-time)
VITE_API_BASE_URL=https://hm-amb.hanmam.kr/api/v1

# Portal API
PORTAL_API_PORT=3020
PORTAL_JWT_SECRET=change_me_portal_jwt_secret
PORTAL_JWT_ACCESS_EXPIRATION=30m
PORTAL_JWT_REFRESH_EXPIRATION=14d
PORTAL_CORS_ORIGINS=https://hm-amb.hanmam.kr
PORTAL_FRONTEND_URL=https://hm-amb.hanmam.kr
PORTAL_SMTP_FROM=AMB Portal <noreply@amoeba.co.kr>
PORTAL_VITE_API_BASE_URL=https://hm-amb.hanmam.kr/api/v1

# Stripe (Portal)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
