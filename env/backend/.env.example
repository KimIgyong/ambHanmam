NODE_ENV=development
API_PORT=3019
API_PREFIX=api/v1

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5442
DB_USERNAME=amb_user
DB_PASSWORD=amb_password
DB_DATABASE=db_amb_hanmam

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Claude AI
CLAUDE_API_KEY=your_claude_api_key_here

# API Key Encryption
API_KEY_ENCRYPTION_SECRET=your_32byte_encryption_key_here
ENCRYPTION_KEY=your_64char_hex_encryption_key_here

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5189

# Swagger
SWAGGER_ENABLED=true

# SMTP (Mail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=AMB Management <noreply@amoeba.co.kr>

# Frontend URL (for invitation links)
FRONTEND_URL=http://localhost:5189

# Seed Admin
SEED_ADMIN_EMAIL=admin@amoeba.group
SEED_ADMIN_PASSWORD=your_admin_password
SEED_ADMIN_NAME=System Admin

# Google Drive (Service Account)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./secrets/google-service-account.json
GOOGLE_DRIVE_IMPERSONATE_EMAIL=
GOOGLE_DRIVE_BILLING_ROOT_FOLDER_ID=

# E-Invoice (Vietnam)
TVAN_PROVIDER=mock
TVAN_API_URL=
TVAN_API_KEY=
VN_EINV_FORM_NUMBER=1
VN_EINV_REFERENCE_CODE=

# Popbill (Korean NTS Tax Invoice)
POPBILL_PROVIDER=mock
POPBILL_LINK_ID=
POPBILL_SECRET_KEY=
POPBILL_IS_TEST=true
POPBILL_CORP_NUM=

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@amoeba.com

# Redmine Integration
REDMINE_URL=
REDMINE_API_KEY=

# Slack Integration
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_OAUTH_REDIRECT_URI=http://localhost:3019/api/v1/slack/oauth/callback

# AmoebaTalk Integration
# SHARED_SECRET: Must match ATK backend AMB_ATK_SHARED_SECRET (used for JWT signing between systems)
AMB_ATK_SHARED_SECRET=
# CONNECT_URL: AmoebaTalk frontend URL for account connection redirect
AMB_ATK_CONNECT_URL=http://localhost:3002/auth/amb-connect
# API_URL: AmoebaTalk backend API base URL (server-to-server calls)
AMB_ATK_API_URL=http://localhost:3000/api
# API_KEY: Must match ATK backend AMB_INTEGRATION_API_KEY (server-to-server auth)
AMB_ATK_API_KEY=
