{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local", "env/frontend/.env.*"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": ["VITE_API_BASE_URL", "VITE_VAPID_PUBLIC_KEY"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "lint:fix": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["build"]
    },
    "migration:run": {
      "cache": false
    },
    "migration:generate": {
      "cache": false
    }
  }
}
